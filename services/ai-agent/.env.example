# Django
DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# QianWen API
QIANWEN_API_KEY=your_qianwen_api_key_here

# Unstructured PDF parsing (RAG)
UNSTRUCTURED_API_KEY=your_unstructured_api_key_here

# Zhipu Embedding (RAG)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# Milvus vector database (RAG)
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=cardiology_guides

# Redis（Java 内部通信令牌校验）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# LangSmith Tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=cardiology-intelligent-agent

# Optional model parameters
LANGCHAIN_TEMPERATURE=0.7
LANGCHAIN_MAX_TOKENS=2000