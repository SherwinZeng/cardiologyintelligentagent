# 生产构建：默认同域反代 /api → cardiology-session
# 若前后端不同域，改为完整地址，例如 https://api.example.com
VITE_API_BASE_URL=/api
VITE_AUTH_API_BASE_URL=/api

# 版权与备案（浙江）
VITE_COPYRIGHT_OWNER=曾祥瑞@ zengxiangruiit@gmail.com
# 备案号下来后取消注释并填入真实号码，格式示例：浙ICP备2025xxxxxx号-1
# VITE_ICP_NUMBER=浙ICP备2025xxxxxx号-1
VITE_ICP_LINK=https://beian.miit.gov.cn/
# 如有公安备案（浙江），格式示例：浙公网安备3301xxxxxxxxxxxx号
