# 复制为 .env.local 可覆盖本地配置（不会被 Git 跟踪）

# 浏览器侧 API 根路径（仅 VITE_ 前缀会暴露给前端）
# 开发：配合 vite.config.ts 的 /api 代理，指向 cardiology-gateway :30000
# 生产：同域 Nginx 反代时通常仍为 /api；跨域部署时改为完整 URL
VITE_API_BASE_URL=/api

# 开发环境 Axios 基址（登录、问诊均经网关）
# VITE_AUTH_API_BASE_URL=http://127.0.0.1:30000

# 版权与 ICP 备案（浙江）
VITE_COPYRIGHT_OWNER=曾祥瑞@ zengxiangruiit@gmail.com
# 浙江 ICP 格式示例：浙ICP备2025xxxxxx号-1
# VITE_ICP_NUMBER=浙ICP备2025xxxxxx号-1
# VITE_ICP_LINK=https://beian.miit.gov.cn/
# 浙江公安备案格式示例：浙公网安备3301xxxxxxxxxxxx号
# VITE_PSB_NUMBER=浙公网安备3301xxxxxxxxxxxx号
# VITE_PSB_LINK=https://www.beian.gov.cn/
