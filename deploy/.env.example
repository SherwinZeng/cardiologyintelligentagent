# ---------- 必填 ----------
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=cardiology
MYSQL_USER=cardiology
MYSQL_PASSWORD=change-me-cardiology

POSTGRES_USER=cardiology
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=cardiology

RABBITMQ_USER=cardiology
RABBITMQ_PASSWORD=change-me-rabbitmq

# gateway 与 auth 必须相同，≥32 字符随机串
JWT_SIGN_KEY=change-me-jwt-sign-key-at-least-32-chars

DJANGO_SECRET_KEY=change-me-django-secret
DEEPSEEK_API_KEY=sk-change-me

# 短信登录（cardiology-auth · 阿里云号码认证 dypnsapi）
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# 若与 application.yml 默认不一致再改（默认：速通互联验证码 / 100001）
# AUTH_SMS_SIGN_NAME=速通互联验证码
# AUTH_SMS_TEMPLATE_CODE=100001

# ---------- 可选 ----------
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ai-agent,cardiology-session,cardiology-gateway,localhost,127.0.0.1
REDIS_DB=0
QIANWEN_API_KEY=

# 指南 RAG（ai-agent · Milvus + 智谱 Embedding + Unstructured PDF）
UNSTRUCTURED_API_KEY=
ZHIPU_API_KEY=
# MILVUS_URI 生产 Compose 内已注入 http://milvus:19530，一般无需改
# MILVUS_COLLECTION=cardiology_guides
# RAG_ENABLED=true
# RAG_TOP_K=5
# RAG_FETCH_K=24

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cardiology-intelligent-agent

VITE_API_BASE_URL=/api
VITE_AUTH_API_BASE_URL=/api
FRONTEND_HTTP_PORT=80

# ---------- Sentinel（可选，v0.3.2+ Compose 已含 sentinel-dashboard 容器）----------
# Java 服务默认连容器名 sentinel-dashboard:8858；不配 Dashboard 也可限流（仅日志 WARN）
# 临时开放控制台端口时，在 docker-compose.prod.yaml 取消 sentinel-dashboard 的 8858 映射
# SENTINEL_DASHBOARD_HOST=sentinel-dashboard
# SENTINEL_DASHBOARD_PORT=8858
