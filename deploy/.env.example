# 云服务器生产环境变量模板
# 用法: cp deploy/.env.example deploy/.env 后填写真实值

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=cardiology
MYSQL_USER=cardiology
MYSQL_PASSWORD=change-me-cardiology

# ---------- Nacos（与 bootstrap.yml 保持一致，生产请修改） ----------
NACOS_USERNAME=nacos
NACOS_PASSWORD=change-me-nacos

# ---------- Django / AI Agent（必填） ----------
DJANGO_SECRET_KEY=change-me-django-secret
DEEPSEEK_API_KEY=sk-change-me

# ---------- Django / AI Agent（可选） ----------
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ai-agent,cardiology-session,localhost,127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
QIANWEN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cardiology-intelligent-agent

# ---------- 前端构建（同域 Nginx 反代，一般不用改） ----------
VITE_API_BASE_URL=/api

# ---------- 对外端口（仅前端 Nginx） ----------
FRONTEND_HTTP_PORT=80
